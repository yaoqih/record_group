.agreement-page { padding-top: 20rpx; padding-bottom: calc(224rpx + env(safe-area-inset-bottom)); }
.agreement-hero { padding: 30rpx 30rpx 34rpx; border-radius: 28rpx; background: linear-gradient(145deg, #ffffff, #edf8f5); border: 1rpx solid rgba(8, 112, 93, .1); box-shadow: var(--rf-shadow-card); }
.agreement-icon { display: flex; align-items: center; justify-content: center; width: 76rpx; height: 76rpx; margin-bottom: 24rpx; border-radius: 22rpx; background: var(--rf-color-brand-light); }
.agreement-kicker { color: var(--rf-color-brand); font-size: 20rpx; font-weight: 700; letter-spacing: 3rpx; }
.agreement-title { margin-top: 8rpx; font-size: 44rpx; font-weight: 750; line-height: 1.25; }
.agreement-meta { margin-top: 12rpx; color: var(--rf-color-secondary); font-size: 23rpx; }
.agreement-notice { display: flex; align-items: flex-start; gap: 12rpx; margin: 22rpx 0; padding: 22rpx; border-radius: 18rpx; background: var(--rf-color-brand-light); color: #315e54; font-size: 24rpx; line-height: 1.65; }
.agreement-error { margin: -4rpx 0 22rpx; }
.agreement-card { padding: 4rpx 28rpx; border-radius: var(--rf-radius-card); background: var(--rf-color-surface); border: 1rpx solid rgba(20, 65, 55, .08); box-shadow: var(--rf-shadow-card); }
.agreement-section { display: flex; align-items: flex-start; gap: 18rpx; padding: 28rpx 0; border-bottom: 1rpx solid var(--rf-color-border); }
.agreement-section-last { border-bottom: 0; }
.section-index { flex: 0 0 auto; padding-top: 4rpx; color: #8e9d99; font-size: 20rpx; font-weight: 700; letter-spacing: 1rpx; }
.section-content { min-width: 0; flex: 1; }
.section-title { margin: 0 0 12rpx; font-size: 29rpx; font-weight: 700; line-height: 1.4; }
.section-text { color: #52635f; font-size: 25rpx; line-height: 1.8; text-align: justify; }
.contact-box { margin-top: 16rpx; padding: 20rpx; border-radius: 16rpx; background: #f5f8f7; }
.contact-value { color: var(--rf-color-text); font-size: 25rpx; font-weight: 600; overflow-wrap: anywhere; }
.contact-method { margin-top: 8rpx; }
.contact-note { margin-top: 8rpx; color: #8a4b13; font-size: 22rpx; line-height: 1.55; }
.agreement-footer-space { height: 1rpx; }
.agreement-action { position: fixed; z-index: 10; right: 0; bottom: 0; left: 0; padding: 14rpx 28rpx calc(18rpx + env(safe-area-inset-bottom)); background: rgba(255, 255, 255, .96); border-top: 1rpx solid var(--rf-color-border); }
.agreement-action-inner { max-width: 750rpx; margin: 0 auto; }
.agreement-action-state { display: flex; align-items: center; justify-content: center; gap: 8rpx; margin-bottom: 10rpx; color: var(--rf-color-secondary); font-size: 22rpx; }
.withdraw-action { padding: 14rpx 0 0; color: #b42318; font-size: 22rpx; text-align: center; }
