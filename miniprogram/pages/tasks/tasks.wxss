.tasks-header { margin-bottom: 24rpx; }
.overview-card { display: flex; align-items: stretch; margin-bottom: 24rpx; padding: 24rpx 8rpx; border-radius: 24rpx; background: linear-gradient(135deg, #fff, #f5fbf9); box-shadow: 0 10rpx 30rpx rgba(16,45,38,.05); }.overview-item { flex: 1; text-align: center; }.overview-number { font-size: 38rpx; font-weight: 750; line-height: 1.2; }.overview-number.accent { color: #0d8a72; }.overview-label { margin-top: 6rpx; color: #71817c; font-size: 21rpx; }.overview-divider { width: 1rpx; background: #e3ebe8; }
.filter-scroll { width: calc(100% + 28rpx); margin: 0 -14rpx 22rpx; white-space: nowrap; }.filter-row { display: inline-flex; gap: 12rpx; padding: 0 14rpx; }
.task-list { display: flex; flex-direction: column; gap: 18rpx; }.task-card { position: relative; overflow: hidden; border-radius: 24rpx; background: #fff; box-shadow: 0 10rpx 30rpx rgba(16,45,38,.05); }.task-card:active { background: #f8fbfa; }.task-accent { position: absolute; left: 0; top: 0; bottom: 0; width: 7rpx; background: #b8c4c0; }.task-accent-action { background: #f59e0b; }.task-accent-processing { background: #3b82f6; }.task-accent-completed { background: #0d9c7e; }.task-accent-failed { background: #ef4444; }
.task-card-body { padding: 24rpx 22rpx 22rpx 28rpx; }.task-row-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 16rpx; }.task-title { min-width: 0; flex: 1; font-size: 29rpx; font-weight: 680; line-height: 1.4; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }.task-info { display: flex; gap: 26rpx; margin-top: 15rpx; color: #71817c; font-size: 23rpx; }.task-info view { display: flex; align-items: center; gap: 7rpx; }.task-footer { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; margin-top: 20rpx; padding-top: 18rpx; border-top: 1rpx solid #edf1f0; }.created-text { color: #91a09c; font-size: 21rpx; }.open-hint { display: flex; align-items: center; color: #08705d; font-size: 22rpx; font-weight: 600; }.task-error { margin-top: 14rpx; color: #b42318; font-size: 23rpx; line-height: 1.45; }.empty-card { margin-top: 8rpx; }
.loading-card { display: flex; align-items: center; justify-content: center; gap: 14rpx; min-height: 240rpx; color: #71817c; font-size: 24rpx; }
