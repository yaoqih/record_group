.mine-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  min-width: 0;
}

.mine-title-row .page-title {
  min-width: 0;
  flex: 1;
}

.user-id-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  max-width: 360rpx;
  padding: 10rpx 14rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  background: #f0fdfa;
  color: #0f766e;
}

.user-id-pill:active {
  background: #ccfbf1;
}

.user-id-text {
  min-width: 0;
  flex: 1;
  font-size: 22rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.wallet-panel {
  border-color: #99f6e4;
  padding: 24rpx;
}

.wallet-balance {
  padding: 22rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  background: #ecfdf5;
}

.wallet-label {
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.35;
}

.wallet-value {
  margin-top: 8rpx;
  color: #0f172a;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.1;
  overflow-wrap: anywhere;
  word-break: break-all;
}

.pay-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
}

.custom-pay {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
  margin-top: 20rpx;
}

.custom-input {
  min-width: 0;
  flex: 1;
}

.custom-button {
  flex: 0 0 220rpx;
}

.manage-panel {
  background: transparent;
  border-color: transparent;
  padding: 0;
}
