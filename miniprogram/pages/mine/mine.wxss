.mine-page { padding-top: 20rpx; }.profile-card { position: relative; overflow: hidden; padding: 30rpx; border-radius: 30rpx; background: linear-gradient(145deg, #0b725f, #075448); color: #fff; box-shadow: 0 18rpx 46rpx rgba(7,84,72,.2); }.profile-glow { position: absolute; right: -110rpx; bottom: -160rpx; width: 390rpx; height: 390rpx; border-radius: 50%; background: rgba(103,226,195,.13); }.profile-top { position: relative; display: flex; align-items: center; gap: 16rpx; }.avatar { display: flex; align-items: center; justify-content: center; width: 88rpx; height: 88rpx; flex: 0 0 auto; border-radius: 26rpx; background: rgba(255,255,255,.16); font-size: 34rpx; font-weight: 700; }.profile-main { min-width: 0; flex: 1; }.profile-name { font-size: 30rpx; font-weight: 700; }.profile-id { display: flex; align-items: center; gap: 8rpx; max-width: 390rpx; margin-top: 7rpx; color: #b9e8dc; font-size: 21rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }.profile-refresh { flex: 0 0 auto; }.wallet-block { position: relative; display: flex; align-items: flex-end; justify-content: space-between; margin-top: 34rpx; padding-top: 28rpx; border-top: 1rpx solid rgba(255,255,255,.15); }.wallet-label { color: #b9e8dc; font-size: 22rpx; }.wallet-value { margin-top: 6rpx; font-size: 54rpx; font-weight: 760; line-height: 1.1; }.wallet-value text { font-size: 23rpx; font-weight: 500; }.wallet-note { padding: 9rpx 13rpx; border-radius: 999rpx; background: rgba(255,255,255,.1); color: #c9e9e1; font-size: 20rpx; }
.recharge-section { margin-top: 34rpx; }.point-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; margin-bottom: 18rpx; }.point-option { position: relative; padding: 23rpx 8rpx 20rpx; border: 2rpx solid transparent; border-radius: 20rpx; background: #fff; text-align: center; }.point-option-active { border-color: #0d8a72; background: #effaf7; }.point-amount { color: #233631; font-size: 29rpx; font-weight: 720; }.point-amount text { font-size: 18rpx; font-weight: 500; }.point-price { margin-top: 7rpx; color: #82908c; font-size: 21rpx; }.popular-tag { position: absolute; right: -2rpx; top: -12rpx; padding: 4rpx 10rpx; border-radius: 999rpx; background: #ff8a4c; color: #fff; font-size: 17rpx; }.custom-toggle { margin-top: 10rpx; }.custom-pay { display: flex; align-items: center; gap: 12rpx; margin-top: 8rpx; }.custom-input { min-width: 0; flex: 1; }.custom-button { flex: 0 0 150rpx; }
.settings-section { margin-top: 38rpx; }.settings-title { margin-bottom: 16rpx; }.settings-card { overflow: hidden; border-radius: 22rpx; background: #fff; }.setting-row { display: flex; align-items: center; gap: 15rpx; padding: 22rpx; border-bottom: 1rpx solid #edf1f0; }.setting-row:last-child { border-bottom: 0; }.setting-icon { display: flex; align-items: center; justify-content: center; width: 60rpx; height: 60rpx; border-radius: 17rpx; background: #eaf7f3; }.setting-main { min-width: 0; flex: 1; font-size: 25rpx; font-weight: 620; }.setting-main text { display: block; margin-top: 4rpx; color: #91a09c; font-size: 20rpx; font-weight: 400; }.logout-button { margin-top: 24rpx; }.guest-card { margin-top: 80rpx; padding: 40rpx 30rpx; border-radius: 28rpx; background: #fff; text-align: center; }.guest-icon { display: flex; align-items: center; justify-content: center; width: 112rpx; height: 112rpx; margin: 0 auto 20rpx; border-radius: 32rpx; background: #eaf7f3; }.guest-title { font-size: 33rpx; font-weight: 730; }.guest-copy { margin: 12rpx 0 28rpx; color: #71817c; font-size: 24rpx; line-height: 1.6; }
