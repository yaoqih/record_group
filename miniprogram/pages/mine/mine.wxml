<view class="page mine-page">
  <view wx:if="{{user}}" class="profile-card">
    <view class="profile-glow"></view>
    <view class="profile-top"><view class="avatar">{{userInitial}}</view><view class="profile-main"><view class="profile-name">{{displayName}}</view><view class="profile-id" bindtap="copyUserId">ID {{user.id}} <t-icon name="copy" size="24rpx" color="#b9e8dc" /></view></view><t-button class="profile-refresh" theme="light" variant="text" size="small" icon="refresh" loading="{{loading}}" disabled="{{loading}}" bind:tap="loadMe" /></view>
    <view class="wallet-block"><view><view class="wallet-label">可用点数</view><view class="wallet-value">{{user.points_balance}}<text> 点</text></view></view><view class="wallet-note">用于录音转写</view></view>
  </view>

  <view wx:if="{{user}}" class="recharge-section">
    <view class="section-heading"><view><view class="section-title">充值点数</view><view class="section-note">按微信现网道具价格结算</view></view><t-icon name="wallet" size="40rpx" color="#07c160" /></view>
    <view class="point-grid">
      <view wx:for="{{pointOptions}}" wx:key="points" class="point-option {{selectedPoints == item.points ? 'point-option-active' : ''}}" data-points="{{item.points}}" bindtap="selectPoints"><view class="point-amount">{{item.points}}<text> 点</text></view><view class="point-price">¥{{item.price}}</view><view wx:if="{{item.tag}}" class="popular-tag">{{item.tag}}</view></view>
    </view>
    <t-button block theme="primary" icon="wallet" loading="{{paying}}" disabled="{{paying}}" data-points="{{selectedPoints}}" bind:tap="recharge">微信支付 ¥{{selectedPrice}}</t-button>
  </view>

  <view wx:if="{{!user}}" class="guest-card"><view class="guest-icon"><t-icon name="user-circle" size="64rpx" color="#08705d" /></view><view class="guest-title">登录 RecordFlow</view><view class="guest-copy">同步任务、管理点数并随时查看转写结果。</view><t-button block theme="primary" icon="logo-wechat" bind:tap="goLogin">去登录</t-button></view>

  <view wx:if="{{user}}" class="settings-section">
    <view class="section-title settings-title">账户设置</view>
    <view class="settings-card"><view class="setting-row" bindtap="openPointLedger"><view class="setting-icon"><t-icon name="wallet" size="30rpx" color="#08705d" /></view><view class="setting-main"><view>点数明细</view><text>查看充值、消耗和退还记录</text></view><t-icon name="arrow-right" size="28rpx" color="#a1afab" /></view><view class="setting-row" bindtap="copyUserId"><view class="setting-icon"><t-icon name="copy" size="30rpx" color="#08705d" /></view><view class="setting-main"><view>账户标识</view><text>点击复制用户 ID</text></view><t-icon name="arrow-right" size="28rpx" color="#a1afab" /></view><view class="setting-row" bindtap="loadMe"><view class="setting-icon"><t-icon name="refresh" size="30rpx" color="#08705d" /></view><view class="setting-main"><view>同步账户</view><text>刷新余额与账户状态</text></view><t-icon name="arrow-right" size="28rpx" color="#a1afab" /></view><view class="setting-row" bindtap="openAgreement"><view class="setting-icon"><t-icon name="file-paste" size="30rpx" color="#08705d" /></view><view class="setting-main"><view>用户协议与隐私说明</view><text>查看、同意或撤回当前版本</text></view><t-icon name="arrow-right" size="28rpx" color="#a1afab" /></view></view>
    <t-button class="logout-button" block theme="danger" variant="outline" icon="logout" disabled="{{paying}}" bind:tap="logout">退出登录</t-button>
  </view>
  <view wx:if="{{error}}" class="error-box">{{error}}</view><t-toast id="t-toast" />
</view>
