.task-page { padding-top: 20rpx; }.detail-hero { padding: 20rpx 4rpx 28rpx; }.detail-status { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; }.detail-date { color: #91a09c; font-size: 21rpx; }.detail-title { margin-top: 18rpx; font-size: 38rpx; font-weight: 750; line-height: 1.35; overflow-wrap: anywhere; }.detail-stats { display: flex; margin-top: 26rpx; }.detail-stats view { flex: 1; border-right: 1rpx solid #dfe7e4; }.detail-stats view+view { padding-left: 24rpx; }.detail-stats view:last-child { border-right: 0; }.detail-stats text,.detail-stats label { display: block; }.detail-stats text { font-size: 28rpx; font-weight: 700; }.detail-stats label { margin-top: 6rpx; color: #82908c; font-size: 20rpx; }
.detail-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 520rpx; color: #71817c; font-size: 24rpx; }.loading-mark { display: flex; align-items: center; justify-content: center; width: 100rpx; height: 100rpx; margin-bottom: 18rpx; border-radius: 28rpx; background: #eaf7f3; }.transcript-loading { display: flex; align-items: center; justify-content: center; gap: 13rpx; margin-top: 28rpx; padding: 38rpx 20rpx; border-radius: 22rpx; background: #fff; color: #71817c; font-size: 23rpx; }
.player-card { position: sticky; top: 16rpx; z-index: 10; margin-bottom: 22rpx; padding: 22rpx 24rpx 14rpx; border-radius: 24rpx; background: rgba(255,255,255,.97); box-shadow: 0 14rpx 36rpx rgba(10,70,58,.12); backdrop-filter: blur(20rpx); }.player-head { display: flex; align-items: center; gap: 16rpx; }.play-circle { display: flex; align-items: center; justify-content: center; width: 76rpx; height: 76rpx; flex: 0 0 auto; border-radius: 50%; background: #08705d; }.player-copy { flex: 1; }.player-label { font-size: 26rpx; font-weight: 650; }.player-time { margin-top: 5rpx; color: #82908c; font-size: 22rpx; }.player-slider { display: block; margin: 8rpx -8rpx 0; }
.confirm-card,.processing-card { margin-bottom: 24rpx; padding: 22rpx; border: 1rpx solid #a7d9cc; border-radius: 22rpx; background: #ebf8f4; }.confirm-row,.processing-card { display: flex; align-items: center; gap: 16rpx; }.confirm-icon { display: flex; align-items: center; justify-content: center; width: 66rpx; height: 66rpx; flex: 0 0 auto; border-radius: 18rpx; background: #fff; }.confirm-main { min-width: 0; flex: 1; }.confirm-title { font-size: 26rpx; font-weight: 700; }.confirm-note { margin-top: 5rpx; color: #58736c; font-size: 21rpx; line-height: 1.45; }.notification-option { margin-top: 18rpx; padding-top: 14rpx; border-top: 1rpx solid #cfe8e1; }.notification-checkbox { --td-checkbox-bg-color: transparent; --td-checkbox-vertical-padding: 4rpx 0; --td-checkbox-title-font: 24rpx/36rpx sans-serif; --td-checkbox-description-font: 21rpx/32rpx sans-serif; --td-checkbox-icon-size: 40rpx; }.pulse-dot { width: 22rpx; height: 22rpx; border: 7rpx solid #bde8dd; border-radius: 50%; background: #0d9c7e; }
.transcript-section { margin-top: 34rpx; }
.transcript-card { overflow: hidden; border-radius: 24rpx; background: #fff; box-shadow: 0 10rpx 30rpx rgba(16,45,38,.05); }.utterance { padding: 25rpx 22rpx; border-bottom: 1rpx solid #edf1f0; }.utterance:last-child { border-bottom: 0; }.utterance:active { background: #f3faf7; }.utterance-line { display: flex; align-items: flex-start; gap: 14rpx; }.speaker-avatar { display: flex; align-items: center; justify-content: center; width: 58rpx; height: 58rpx; flex: 0 0 auto; border-radius: 18rpx; background: #eaf7f3; color: #08705d; font-size: 21rpx; font-weight: 700; }.utterance-main { min-width: 0; flex: 1; }.utterance-meta { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }.speaker { color: #52635f; font-size: 22rpx; font-weight: 650; }.timecode { color: #9aa7a3; font-size: 20rpx; }.utterance-text { color: #182925; font-size: 28rpx; line-height: 1.75; overflow-wrap: anywhere; }
.more-section { margin-top: 36rpx; }.more-title { margin-bottom: 14rpx; font-size: 27rpx; font-weight: 700; }.info-card { padding: 8rpx 22rpx; border-radius: 20rpx; background: #fff; }.info-row { display: flex; justify-content: space-between; gap: 30rpx; padding: 18rpx 0; border-bottom: 1rpx solid #edf1f0; color: #82908c; font-size: 22rpx; }.info-row:last-child { border-bottom: 0; }.info-row text:last-child { color: #40534e; text-align: right; }.manage-actions { display: flex; flex-direction: column; gap: 16rpx; margin-top: 24rpx; }.task-error-detail { margin: 14rpx 0; padding: 16rpx; border-radius: 12rpx; background: #fff3f2; color: #b42318; font-size: 23rpx; }
