.player-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 112rpx;
  margin: -8rpx -4rpx 24rpx;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
  border: 1rpx solid #cbd5e1;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.player-button {
  flex: 0 0 auto;
  min-width: 136rpx;
}

.player-main {
  min-width: 0;
  flex: 1;
}

.player-title {
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.35;
  overflow-wrap: anywhere;
  word-break: break-all;
}

.player-time {
  margin-top: 4rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.35;
}

.player-slider {
  display: block;
  margin-top: 8rpx;
}

.detail-header {
  margin-top: 0;
}

.action-panel {
  border-color: #99f6e4;
}

.transcript-header {
  align-items: flex-start;
}

.export-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10rpx;
  max-width: 330rpx;
}

.export-actions t-button {
  flex: 0 0 auto;
}

.utterance {
  padding: 24rpx 0;
  border-top: 1rpx solid #e2e8f0;
}

.utterance:active {
  background: #f8fafc;
}

.utterance-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx 14rpx;
  margin-bottom: 8rpx;
}

.speaker {
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
  overflow-wrap: anywhere;
  word-break: break-all;
}

.timecode {
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.4;
}

.utterance-text {
  font-size: 29rpx;
  line-height: 1.75;
  overflow-wrap: anywhere;
  word-break: break-all;
}

.manage-panel {
  margin-top: 4rpx;
}
