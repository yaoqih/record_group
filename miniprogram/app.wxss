page {
  background: #f6f8fb;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx calc(48rpx + env(safe-area-inset-bottom));
}

.page-header {
  margin: 4rpx 0 28rpx;
}

.eyebrow {
  margin-bottom: 8rpx;
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.page-title {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: 0;
  overflow-wrap: anywhere;
  word-break: break-all;
}

.page-subtitle {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.55;
  overflow-wrap: anywhere;
  word-break: break-all;
}

.panel {
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-sizing: border-box;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
}

.panel-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  min-width: 0;
  margin-bottom: 22rpx;
}

.panel-header-main {
  min-width: 0;
  flex: 1;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
  min-width: 0;
  overflow-wrap: anywhere;
  word-break: break-all;
}

.panel-note {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.5;
  overflow-wrap: anywhere;
  word-break: break-all;
}

.break-text {
  overflow-wrap: anywhere;
  word-break: break-all;
}

.muted {
  color: #64748b;
}

.small-text {
  font-size: 24rpx;
  line-height: 1.5;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-width: 0;
}

.row-main {
  min-width: 0;
  flex: 1;
}

.field {
  margin: 20rpx 0;
}

.action-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.button-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.inline-status {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  min-width: 0;
}

.summary-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.summary-item {
  flex: 1 1 220rpx;
  min-width: 0;
  padding: 18rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  background: #f8fafc;
}

.summary-label {
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.35;
}

.summary-value {
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  overflow-wrap: anywhere;
  word-break: break-all;
}

.meta-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx 18rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.45;
}

.error-box {
  margin-top: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border: 1rpx solid #fecaca;
  border-radius: 8rpx;
  background: #fef2f2;
  color: #b91c1c;
  font-size: 26rpx;
  line-height: 1.55;
  overflow-wrap: anywhere;
  word-break: break-all;
}

.empty-panel {
  padding: 34rpx 0;
}

.empty-action {
  margin-top: 24rpx;
}

.danger-zone {
  border-color: #fecaca;
}
