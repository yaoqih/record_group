page {
  --rf-color-brand: #08705d;
  --rf-color-brand-light: #eaf7f3;
  --rf-color-text: #10201d;
  --rf-color-secondary: #71817c;
  --rf-color-border: #e3ebe8;
  --rf-color-surface: #ffffff;
  --rf-color-page: #f4f7f6;
  --rf-radius-card: 24rpx;
  --rf-radius-control: 16rpx;
  --rf-shadow-card: 0 10rpx 30rpx rgba(16, 45, 38, .05);
  --td-brand-color: #08705d;
  --td-brand-color-active: #075f50;
  --td-brand-color-disabled: #9fc8bd;
  --td-brand-color-light: #eaf7f3;
  --td-text-color-primary: #10201d;
  --td-text-color-secondary: #71817c;
  --td-bg-color-page: #f4f7f6;
  --td-radius-default: 16rpx;
  background: var(--rf-color-page);
  color: var(--rf-color-text);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 28rpx calc(56rpx + env(safe-area-inset-bottom));
}

.page-header { margin: 4rpx 0 32rpx; }
.eyebrow {
  margin-bottom: 10rpx;
  color: var(--rf-color-brand);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
  letter-spacing: 3rpx;
  text-transform: uppercase;
}
.page-title {
  color: var(--rf-color-text);
  font-size: 48rpx;
  font-weight: 750;
  line-height: 1.2;
  letter-spacing: -1rpx;
  overflow-wrap: anywhere;
}
.page-subtitle {
  margin-top: 12rpx;
  color: var(--rf-color-secondary);
  font-size: 26rpx;
  line-height: 1.6;
}
.panel {
  margin-bottom: 22rpx;
  padding: 28rpx;
  box-sizing: border-box;
  background: var(--rf-color-surface);
  border: 1rpx solid rgba(20, 65, 55, .08);
  border-radius: var(--rf-radius-card);
  box-shadow: var(--rf-shadow-card);
}
.panel-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  min-width: 0;
  margin-bottom: 24rpx;
}
.panel-header-main, .row-main { min-width: 0; flex: 1; }
.panel-title { font-size: 31rpx; font-weight: 700; line-height: 1.4; }
.panel-note { margin-top: 7rpx; color: var(--rf-color-secondary); font-size: 24rpx; line-height: 1.55; }
.row { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; min-width: 0; }
.field { margin: 20rpx 0; }
.action-stack { display: flex; flex-direction: column; gap: 16rpx; }
.button-row { display: flex; align-items: center; flex-wrap: wrap; gap: 12rpx; }
.inline-status { display: flex; align-items: center; flex-wrap: wrap; gap: 12rpx; min-width: 0; }
.meta-line { display: flex; align-items: center; flex-wrap: wrap; gap: 10rpx 18rpx; color: var(--rf-color-secondary); font-size: 24rpx; line-height: 1.45; }
.muted { color: var(--rf-color-secondary); }
.small-text { font-size: 24rpx; line-height: 1.5; }
.error-box {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  border: 1rpx solid #fecaca;
  border-radius: var(--rf-radius-control);
  background: #fff5f5;
  color: #b42318;
  font-size: 25rpx;
  line-height: 1.55;
  overflow-wrap: anywhere;
}
.empty-panel { padding: 42rpx 0; }
.empty-action { margin-top: 24rpx; }
.danger-zone { border-color: #fecaca; }
.soft-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 9rpx 14rpx;
  border-radius: 999rpx;
  background: var(--rf-color-brand-light);
  color: var(--rf-color-brand);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.3;
}

.section-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.section-title {
  color: var(--rf-color-text);
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.4;
}

.section-note {
  margin-top: 5rpx;
  color: var(--rf-color-secondary);
  font-size: 22rpx;
  line-height: 1.45;
}
