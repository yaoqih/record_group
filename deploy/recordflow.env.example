RECORDFLOW_ENV=production
DATABASE_URL=postgresql://recordflow:change-me@127.0.0.1:5432/recordflow

# Use "filesystem" when OSS is mounted on the server, for example /record.
# Leave as "b2" to use Backblaze B2.
RECORDFLOW_MEDIA_STORAGE_BACKEND=b2
RECORDFLOW_FS_STORAGE_ROOT=/record
RECORDFLOW_FS_PUBLIC_BASE_URL=

# Temporary raw uploads before backend compression. Useful when /record is an
# OSS/COS mount with lifecycle cleanup.
RECORDFLOW_PENDING_UPLOAD_ROOT=/record/production/pending
RECORDFLOW_PENDING_UPLOAD_PUBLIC_BASE_URL=
RECORDFLOW_COS_BUCKET=
RECORDFLOW_COS_REGION=
RECORDFLOW_COS_DIRECT_UPLOAD_PREFIX=production/pending
RECORDFLOW_COS_DIRECT_UPLOAD_PUBLIC_WRITE=false
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
RECORDFLOW_DIRECT_UPLOAD_TTL_SECONDS=900

RECORDFLOW_LLM_BASE_URL=https://yunwu.ai/v1
RECORDFLOW_LLM_MODEL=deepseek-v4-flash
RECORDFLOW_LLM_API_KEY=

RECORDFLOW_STEPFUN_API_KEY=
RECORDFLOW_STEPFUN_BASE_URL=https://api.stepfun.com
RECORDFLOW_STEPFUN_ASR_MODEL=stepaudio-2.5-asr
RECORDFLOW_STEPFUN_ASR_LANGUAGE=zh
RECORDFLOW_STEPFUN_ENABLE_ITN=true
RECORDFLOW_STEPFUN_TIMEOUT_SECONDS=300
# File-ASR polling starts responsive, then backs off to reduce idle API calls.
RECORDFLOW_STEPFUN_POLL_INTERVAL_SECONDS=1
RECORDFLOW_STEPFUN_POLL_MAX_INTERVAL_SECONDS=5
RECORDFLOW_STEPFUN_POLL_JITTER_RATIO=0.1

RECORDFLOW_SESSION_SECRET=change-me-to-a-long-random-string
# Required to access management APIs such as /site/admin/dashboard.
RECORDFLOW_APP_API_KEY=change-me-to-a-separate-admin-api-key
RECORDFLOW_MINIAPP_SIGNUP_POINTS=100
# Keep true after the mini-program version containing the v2 consent screen is released.
RECORDFLOW_REQUIRE_AGREEMENT=true
WECHAT_MINIAPP_APPID=
WECHAT_MINIAPP_SECRET=
WECHAT_VIRTUAL_OFFER_ID=
WECHAT_VIRTUAL_MODE=short_series_goods
WECHAT_VIRTUAL_PRODUCT_ID=
WECHAT_VIRTUAL_PRODUCTION_APPKEY=
WECHAT_MESSAGE_TOKEN=
WECHAT_MESSAGE_ENCODING_AES_KEY=
# Optional one-time task completion subscription. Leave the template ID empty
# to disable this feature without changing application code.
WECHAT_SUBSCRIBE_TASK_COMPLETE_TEMPLATE_ID=
WECHAT_SUBSCRIBE_TASK_COMPLETE_TITLE_FIELD=thing3
WECHAT_SUBSCRIBE_TASK_COMPLETE_STATUS_FIELD=thing2
WECHAT_SUBSCRIBE_TASK_COMPLETE_TIME_FIELD=time1
WECHAT_SUBSCRIBE_TASK_COMPLETE_STATUS_VALUE=转写完成
WECHAT_SUBSCRIBE_TASK_COMPLETE_PAGE=pages/task/task?id={task_id}
WECHAT_SUBSCRIBE_MINIPROGRAM_STATE=formal
WECHAT_SUBSCRIBE_TIMEOUT_SECONDS=5

# Process-local protection for sensitive endpoints. Set ENABLED=false only
# when an equivalent gateway/WAF limit is configured.
RECORDFLOW_RATE_LIMIT_ENABLED=true
RECORDFLOW_RATE_LIMIT_WINDOW_SECONDS=60
RECORDFLOW_RATE_LIMIT_AUTH_REQUESTS=20
RECORDFLOW_RATE_LIMIT_DIRECT_UPLOAD_INIT_REQUESTS=30
RECORDFLOW_RATE_LIMIT_TASK_UPLOAD_REQUESTS=12
RECORDFLOW_RATE_LIMIT_VIRTUAL_PAYMENT_REQUESTS=12
RECORDFLOW_RATE_LIMIT_EXPORT_REQUESTS=60
RECORDFLOW_RATE_LIMIT_MAX_KEYS=10000
# Enable only when the API is reachable exclusively through a trusted proxy.
RECORDFLOW_TRUST_PROXY_HEADERS=true

RECORDFLOW_B2_KEY_ID=
RECORDFLOW_B2_APPLICATION_KEY=
RECORDFLOW_B2_BUCKET_NAME=
RECORDFLOW_B2_BUCKET_ID=
RECORDFLOW_B2_PUBLIC_BASE_URL=
RECORDFLOW_B2_CDN_BASE_URL=
